{
  "name": "Fica Dica Scraper",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postStartCommand": "pip install -r requirements.txt && playwright install chromium --with-deps",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "GitHub.copilot"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "forwardPorts": [8766],
  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}"
  }
}
