# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── CoinGecko ────────────────────────────────────────────────────────────────
COINGECKO_API_KEY=your_coingecko_api_key_here   # Pro tier opcional

# ── Mercado Bitcoin ───────────────────────────────────────────────────────────
MB_API_ID=your_mb_api_id_here
MB_API_SECRET=your_mb_api_secret_here
MB_TAPI_ID=your_mb_tapi_id_here       # Trade API (ordens)
MB_TAPI_SECRET=your_mb_tapi_secret_here

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── App config ────────────────────────────────────────────────────────────────
DB_PATH=./data/crypto_advisor.db
# BINANCE_VERIFY_SSL=false  # descomente se usar DevContainer/proxy com cert autoassinado
REPORT_SCHEDULE_DAY=sunday
REPORT_SCHEDULE_HOUR=18
REPORT_SCHEDULE_MINUTE=0

# ── Tax config ────────────────────────────────────────────────────────────────
TAX_MONTHLY_LIMIT_BRL=35000.00      # IN RFB 2.312/2026 isenção mensal
TAX_WARNING_THRESHOLD_BRL=28000.00  # alerta: ~80% do limite
TAX_CRITICAL_THRESHOLD_BRL=33000.00 # crítico: ~94% do limite
