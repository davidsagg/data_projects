{
  "name": "crypto-advisor-dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "workspaceFolder": "/workspaces/crypto_advisor",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/crypto_advisor,type=bind,consistency=cached",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },

  "mounts": [
    "source=crypto-advisor-data,target=/workspaces/crypto_advisor/data,type=volume"
  ],

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "forwardPorts": [8765, 8501],
  "portsAttributes": {
    "8765": { "label": "CryptoAdvisor Dashboard" },
    "8501": { "label": "Streamlit UI (legado)" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "ms-python.mypy-type-checker",
        "tamasfe.even-better-toml",
        "streetsidesoftware.code-spell-checker",
        "streetsidesoftware.code-spell-checker-portuguese-brazilian"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.rulers": [100],
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  }
}
