{
  "name": "bandkit-dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "workspaceFolder": "/workspaces/bandkit",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/bandkit,type=bind,consistency=cached",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "postCreateCommand": "cd backend && pip install -r requirements.txt && cd ../frontend && npm install && pip install jupyter",
  "forwardPorts": [8000, 5173],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python", "ms-python.black-formatter",
        "charliermarsh.ruff", "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode", "bradlc.vscode-tailwindcss",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
