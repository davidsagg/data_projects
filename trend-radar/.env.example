# Copie para .env e preencha com suas chaves reais
# NUNCA commite o .env — ele está no .gitignore

# APIs de música (obrigatórias para ingestão)
LASTFM_API_KEY=sua-chave-aqui
YOUTUBE_API_KEY=sua-chave-aqui

# Configurações opcionais
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
DUCKDB_PATH=/workspace/data/trend_radar.duckdb
ANOMALY_ZSCORE_THRESHOLD=2.5
TREND_THRESHOLD=65
LOG_LEVEL=INFO
